/* Main TUI stylesheet - Split-Pane Layout */

Screen {
    background: #1e1e1e;
    color: #cccccc;
    layout: horizontal;
}

/* Main horizontal split: 65% left (chat), 35% right (context) */
#app_grid {
    layout: horizontal;
    width: 100%;
    height: 100%;
}

/* Left side: Chat and Input (Takes roughly 65% of width) */
#main_area {
    width: 2fr;
    height: 100%;
    layout: vertical;
    border-right: solid #333333;
}

#chat_output {
    height: 1fr;
    background: #1e1e1e;
    border-bottom: solid #333333;
    padding: 0 1;
}

#sys_log {
    height: 30%;
    background: #000000;
    color: #888888;
    border-bottom: solid #333333;
    padding: 0 1;
}

#input_container {
    height: auto;
    background: #1e1e1e;
    padding: 1 2;
}

#input_status_bar {
    height: 1;
    margin-bottom: 1;
}

#mode_info {
    width: auto;
    color: #4fc1ff;
    margin-right: 2;
    text-style: bold;
}

#provider_model_info {
    width: 1fr;
    color: #9cdcfe;
}

#chat_input {
    dock: bottom;
    border: tall #333333;
    background: #252526;
    height: auto;
}

#chat_input:focus {
    border: tall #007acc;
}

#input_legend {
    height: 1;
    margin-top: 1;
    color: #808080;
}

/* Right side: Context, Workspace, and Task State (Fixed width sidebar) */
#sidebar {
    width: 35;
    height: 100%;
    background: #252526;
    layout: vertical;
    padding: 1 2;
}

#sidebar_top {
    height: 1fr;
}

#sidebar_bottom {
    height: auto;
    border-top: solid #333333;
    padding-top: 1;
}

.sidebar_title {
    text-style: bold;
    color: #d4d4d4;
    margin-bottom: 1;
}

#context_info, #working_dir_info {
    color: #999999;
}